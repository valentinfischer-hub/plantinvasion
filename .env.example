# Plantinvasion - Vite-Env-Vars (Build-Time)
# Kopiere diese Datei zu .env.local und passe die Werte an. .env.local ist gitignored.

# Multiplayer-Master-Flag. true aktiviert Supabase-Init, Realtime-Kanaele und Trade-UI.
# Default false bis S-11 Multiplayer-Foundation steht.
VITE_MP_ENABLED=false

# Debug-Overlay (FPS, Hitboxes, RNG-Trace). Nur fuer lokale Dev-Sessions.
VITE_DEBUG_OVERLAY=false

# Supabase Backend (nur lesend wenn VITE_MP_ENABLED=true).
# Werte aus Supabase-Dashboard -> Project Settings -> API.
# VITE_SUPABASE_URL=https://<your-project>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your-anon-key>
